# Copy to .env.local and set TFL_APP_KEY (TfL Unified API primary key).
# Docker Compose reads .env.local when you use: docker compose --env-file .env.local up

TFL_APP_KEY=

# Optional: TfL "Application ID" if your app registration uses app_id + app_key
TFL_APP_ID=

POSTGRES_USER=tfl
POSTGRES_PASSWORD=tfl_secret
POSTGRES_DB=tfl_bus

# JDBC for hub sync + bus_positions sink (Java job)
FLINK_JDBC_URL=jdbc:postgresql://postgres:5432/tfl_bus

# StopPoint types for hub_stops sync (comma-separated TfL Meta/StopTypes ids). Leave empty to sync all bus-related types (any Meta id containing "bus", plus TransportInterchange).
# Example: NaptanPublicBusCoachTram,NaptanOnstreetBusCoachStop
TFL_HUB_STOP_TYPES=

TFL_GHOST_DEFAULT_SEGMENT_SECS=360
# Tick interval for TfL polls (ms); tick-feed uses the same value.
TFL_POLL_INTERVAL_MS=30000

# Parallel TfL /Arrivals HTTP calls per tick (1–64). Raise for 19k+ stops (e.g. 48).
TFL_ARRIVAL_POLL_PARALLELISM=32

# Hostname for the tick TCP service (docker service name by default)
TFL_TICK_HOST=tick-feed
TFL_TICK_PORT=9999
